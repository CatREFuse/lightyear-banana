{
  "name": "lightyear-banana",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node scripts/electron-dev.mjs",
    "build": "npm run build:web",
    "build:web": "vue-tsc -b && vite build",
    "build:uxp": "vue-tsc -b && vite build --config vite.uxp.config.ts",
    "build:uxp:watch": "vite build --config vite.uxp.config.ts --watch",
    "mock:image-api": "node scripts/mock-image-api-server.mjs",
    "package:electron:mac": "npm run build:web && npm run package:uxp && node scripts/package-electron-mac.mjs",
    "package:electron:win": "npm run build:web && node scripts/package-electron-win.mjs",
    "package:uxp": "npm run verify:uxp && cd dist/ps-uxp && zip -r -q ../${npm_package_name}-${npm_package_version}.ccx .",
    "verify:uxp": "npm run build:uxp && node scripts/verify-uxp-build.mjs",
    "preview": "vite preview",
    "start:electron": "electron electron/main.js"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^39.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
