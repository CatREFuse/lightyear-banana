{
  "manifestVersion": 5,
  "id": "com.tanshow.lightyearbanana",
  "name": "Lightyear Banana",
  "version": "0.1.0",
  "main": "uxp-panel.html",
  "host": {
    "app": "PS",
    "minVersion": "27.3.0",
    "data": {
      "apiVersion": 2
    }
  },
  "requiredPermissions": {
    "network": {
      "domains": "all"
    }
  },
  "entrypoints": [
    {
      "type": "command",
      "id": "createLayer",
      "label": {
        "default": "创建图层"
      }
    },
    {
      "type": "panel",
      "id": "panel",
      "label": {
        "default": "Lightyear Banana"
      },
      "minimumSize": {
        "width": 260,
        "height": 220
      },
      "maximumSize": {
        "width": 1200,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 420
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 520
      },
      "icons": [
        {
          "width": 23,
          "height": 23,
          "path": "icons/dark.png",
          "scale": [1, 2],
          "theme": ["darkest", "dark", "medium"]
        },
        {
          "width": 23,
          "height": 23,
          "path": "icons/light.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/icon_D.png",
      "scale": [1, 2],
      "theme": ["dark", "darkest"],
      "species": ["generic"]
    },
    {
      "width": 23,
      "height": 23,
      "path": "icons/icon_N.png",
      "scale": [1, 2],
      "theme": ["lightest", "light"],
      "species": ["generic"]
    }
  ]
}
