{
  "manifestVersion": 5,
  "id": "com.tanshow.lightyearbanana.standalone",
  "name": "Lightyear Banana Standalone",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "27.3.0",
    "data": {
      "apiVersion": 2
    }
  },
  "entrypoints": [
    {
      "type": "command",
      "id": "createLayer",
      "label": {
        "default": "创建图层"
      }
    },
    {
      "type": "panel",
      "id": "panel",
      "label": {
        "default": "Lightyear Banana Standalone"
      },
      "minimumSize": {
        "width": 280,
        "height": 260
      },
      "maximumSize": {
        "width": 960,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 520
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 620
      }
    }
  ]
}
